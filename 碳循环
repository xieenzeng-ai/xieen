+<body>
+  <div class="container">
+    <h1>BMI & 减脂工具（含胚型与碳循环）</h1>
+
+    <div class="form-grid">
+      <label>身高 (cm)
+        <input id="height" type="number" min="100" max="250" step="0.1" />
+      </label>
+
+      <label>当前体重 (kg)
+        <input id="weight" type="number" min="25" max="300" step="0.1" />
+      </label>
+
+      <label>目标体重 (kg)
+        <input id="targetWeight" type="number" min="25" max="300" step="0.1" />
+      </label>
+
+      <label>年龄
+        <input id="age" type="number" min="12" max="100" />
+      </label>
+
+      <label>性别
+        <select id="gender">
+          <option value="male">男</option>
+          <option value="female">女</option>
+        </select>
+      </label>
+
+      <label>活动水平
+        <select id="activity">
+          <option value="1.2">久坐（几乎不运动）</option>
+          <option value="1.375">轻活动（每周1-3次）</option>
+          <option value="1.55" selected>中等活动（每周3-5次）</option>
+          <option value="1.725">高活动（每周6-7次）</option>
+          <option value="1.9">非常高（体力工作+训练）</option>
+        </select>
+      </label>
+
+      <label>胚型选择
+        <select id="somatotype">
+          <option value="ectomorph">外胚型（偏瘦，代谢快）</option>
+          <option value="mesomorph" selected>中胚型（均衡，增肌减脂都较快）</option>
+          <option value="endomorph">内胚型（易囤脂，代谢相对慢）</option>
+        </select>
+      </label>
+    </div>
+
+    <button onclick="calculate()">开始计算</button>
+
+    <div class="result" id="result">请填写数据后点击“开始计算”。</div>
+  </div>
+
+<script>
+function getBmiLevel(bmi) {
+  if (bmi < 18.5) return "偏瘦";
+  if (bmi < 24) return "正常";
+  if (bmi < 28) return "超重";
+  return "肥胖";
+}
+
+function calculate() {
+  const height = parseFloat(document.getElementById("height").value);
+  const weight = parseFloat(document.getElementById("weight").value);
+  const targetWeight = parseFloat(document.getElementById("targetWeight").value);
+  const age = parseFloat(document.getElementById("age").value);
+  const gender = document.getElementById("gender").value;
+  const activity = parseFloat(document.getElementById("activity").value);
+  const somatotype = document.getElementById("somatotype").value;
+
+  if (!height || !weight || !targetWeight || !age || !activity) {
+    document.getElementById("result").textContent = "请填写完整且有效的信息。";
+    return;
+  }
+
+  if (targetWeight >= weight) {
+    document.getElementById("result").textContent = "目标体重需要小于当前体重，才是减脂计划。";
+    return;
+  }
+
+  const bmi = weight / ((height / 100) ** 2);
+  const bmiLevel = getBmiLevel(bmi);
+
+  const bmr = gender === "male"
+    ? 10 * weight + 6.25 * height - 5 * age + 5
+    : 10 * weight + 6.25 * height - 5 * age - 161;
+
+  const maintenanceCalories = bmr * activity;
+
+  const deficitRatioByType = {
+    ectomorph: 0.12,
+    mesomorph: 0.17,
+    endomorph: 0.22
+  };
+
+  const deficitCalories = maintenanceCalories * (1 - deficitRatioByType[somatotype]);
+
+  const carbCycleByType = {
+    ectomorph: [0.45, 0.40, 0.35],
+    mesomorph: [0.40, 0.32, 0.25],
+    endomorph: [0.32, 0.24, 0.18]
+  };
+
+  const proteinPerKgByType = {
+    ectomorph: 1.8,
+    mesomorph: 2.0,
+    endomorph: 2.2
+  };
+
+  const fatFloorRatioByType = {
+    ectomorph: 0.22,
+    mesomorph: 0.25,
+    endomorph: 0.30
+  };
+
+  const [highRatio, midRatio, lowRatio] = carbCycleByType[somatotype];
+  const proteinGram = weight * proteinPerKgByType[somatotype];
+  const proteinCalories = proteinGram * 4;
+  const fatFloorCalories = deficitCalories * fatFloorRatioByType[somatotype];
+
+  const weeklyPlan = [
+    { day: "周一（高碳）", ratio: highRatio },
+    { day: "周二（中碳）", ratio: midRatio },
+    { day: "周三（低碳）", ratio: lowRatio },
+    { day: "周四（高碳）", ratio: highRatio },
+    { day: "周五（中碳）", ratio: midRatio },
+    { day: "周六（低碳）", ratio: lowRatio },
+    { day: "周日（低碳）", ratio: lowRatio }
+  ];
+
+  const rows = weeklyPlan.map((item) => {
+    const dailyCalories = deficitCalories;
+    const carbCalories = dailyCalories * item.ratio;
+    const carbGram = carbCalories / 4;
+    const fatCalories = Math.max(dailyCalories - carbCalories - proteinCalories, fatFloorCalories);
+    const fatGram = fatCalories / 9;
+    return `
+      <tr>
+        <td>${item.day}</td>
+        <td>${Math.round(dailyCalories)} kcal</td>
+        <td>${Math.round(item.ratio * 100)}%</td>
+        <td>${Math.round(carbGram)} g</td>
+        <td>${Math.round(proteinGram)} g</td>
+        <td>${Math.round(fatGram)} g</td>
+      </tr>`;
+  }).join("");
+
+  const weightToLose = weight - targetWeight;
+  const totalCaloriesNeeded = weightToLose * 7700;
+  const dailyDeficit = maintenanceCalories - deficitCalories;
+  const daysNeeded = totalCaloriesNeeded / dailyDeficit;
+
+  document.getElementById("result").innerHTML = `
+    <h2>计算结果</h2>
+    BMI：<b>${bmi.toFixed(1)}</b>（${bmiLevel}）<br>
+    维持热量：<b>${Math.round(maintenanceCalories)} kcal/天</b><br>
+    减脂建议摄入：<b>${Math.round(deficitCalories)} kcal/天</b><br>
+    蛋白质建议：<b>${Math.round(proteinGram)} g/天</b><br>
+    脂肪建议：<b>${Math.round(fatFloorCalories / 9)} g/天起</b><br>
+    目标减重：<b>${weightToLose.toFixed(1)} kg</b><br>
+    预计周期：<b>${Math.round(daysNeeded)} 天</b>
+
+    <h2>碳循环周表</h2>
+    <table>
+      <thead>
+        <tr>
+          <th>日期</th>
+          <th>总热量</th>
+          <th>碳水占比</th>
+          <th>建议碳水</th>
+          <th>建议蛋白质</th>
+          <th>建议脂肪</th>
+        </tr>
+      </thead>
+      <tbody>${rows}</tbody>
+    </table>
+    <p class="muted">提示：以上为估算值，请结合训练与体重周均变化每2周微调一次摄入。</p>
+  `;
+}
+</script>
+</body>
+</html>
 
